{
  "entities": {
    "LeaderboardEntry": {
      "title": "LeaderboardEntry",
      "description": "Represents an individual tapper's run score record",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier of the record" },
        "name": { "type": "string", "description": "Nickname of the player" },
        "time": { "type": "number", "description": "Completing time in seconds" },
        "accuracy": { "type": "number", "description": "Accuracy percentage of taps" },
        "date": { "type": "string", "description": "Date format YYYY-MM-DD" },
        "isPlayer": { "type": "boolean", "description": "True if submitted by the current user" }
      },
      "required": ["id", "name", "time", "accuracy", "date"]
    }
  },
  "firestore": {
    "leaderboard/{recordId}": {
      "schema": "#/entities/LeaderboardEntry",
      "description": "Collection of speed tap leaderboard entries"
    }
  }
}
